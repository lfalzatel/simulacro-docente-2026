rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPERS
    // ============================================
    function getRol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function estaAutenticado() {
      return request.auth != null;
    }

    function esAdmin() {
      return estaAutenticado() && getRol() == 'admin';
    }

    function esProfesor() {
      return estaAutenticado() && getRol() == 'profesor';
    }

    function esCreadorDelExamen(profesorId) {
      return estaAutenticado() && request.auth.uid == profesorId;
    }

    // ============================================
    // USUARIOS (roles: admin / profesor / estudiante / free)
    // ============================================
    match /usuarios/{userId} {
      allow read: if estaAutenticado();

      allow create: if request.auth.uid == userId; // el usuario se crea a sí mismo en el primer login

      allow update: if request.auth.uid == userId
                    || esAdmin()
                    || (esProfesor() && request.resource.data.rol == 'estudiante');
    }

    // ============================================
    // EXAMENES
    // ============================================
    match /examenes/{examenId} {
      allow read: if estaAutenticado();

      // Crear examen: solo profesor/admin, y el documento debe traer los
      // campos mínimos con tipos y rangos válidos (Fase 3).
      allow create: if (esProfesor() || esAdmin())
                    && request.resource.data.profesorId == request.auth.uid
                    && request.resource.data.titulo is string
                    && request.resource.data.titulo.size() > 0
                    && request.resource.data.titulo.size() <= 120
                    && request.resource.data.grupoId is string
                    && request.resource.data.bancoPreguntas in ['quizData', 'quizData2', 'quizData3']
                    && request.resource.data.estado == 'inactivo'   // todo examen nace inactivo
                    && (
                         !('numPreguntas' in request.resource.data)
                         || request.resource.data.numPreguntas == null
                         || (request.resource.data.numPreguntas is int
                             && request.resource.data.numPreguntas > 0
                             && request.resource.data.numPreguntas <= 360)
                       )
                    && (
                         !('duracionMinutos' in request.resource.data)
                         || request.resource.data.duracionMinutos == null
                         || (request.resource.data.duracionMinutos is int
                             && request.resource.data.duracionMinutos > 0
                             && request.resource.data.duracionMinutos <= 240)
                       );

      // Actualizar examen (activar/desactivar/cerrar, editar título, etc.):
      // solo el profesor dueño o un admin, y el estado debe seguir siendo válido.
      allow update: if (esAdmin() || esCreadorDelExamen(resource.data.profesorId))
                    && request.resource.data.estado in ['inactivo', 'activo', 'cerrado'];

      allow delete: if esAdmin() || esCreadorDelExamen(resource.data.profesorId);

      // ============================================
      // INTENTOS (subcolección: un doc por estudiante)
      // ============================================
      match /intentos/{estudianteUid} {
        allow read: if request.auth.uid == estudianteUid || esProfesor() || esAdmin();

        // El estudiante crea su propio intento al entrar por primera vez.
        allow create: if request.auth.uid == estudianteUid
                      && request.resource.data.estado == 'no_iniciado';

        // El estudiante puede actualizar su propio intento (autoguardado de
        // respuestas, o auto-bloquearse al detectar fraude) MIENTRAS no esté
        // ya bloqueado — desbloquear es exclusivo del profesor/admin.
        allow update: if (request.auth.uid == estudianteUid && resource.data.estado != 'bloqueado')
                      || esProfesor()
                      || esAdmin();
      }
    }
  }
}
