rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth.uid == userId
                    || getRol() == 'admin'
                    || (getRol() == 'profesor' && request.resource.data.rol == 'estudiante');
      allow create: if request.auth.uid == userId; // Permitir que un nuevo usuario se cree a sí mismo en el primer login
    }

    match /examenes/{examenId} {
      allow read: if request.auth != null;
      
      // Validar que el profesor está creando el examen correctamente
      allow create: if getRol() in ['profesor', 'admin']
                    && request.resource.data.keys().hasAll(['titulo', 'grupoId', 'profesorId', 'bancoPreguntas', 'estado'])
                    && request.resource.data.estado == 'inactivo'
                    && request.resource.data.profesorId == request.auth.uid;
                    
      // Actualización de estado y configuración
      allow update: if getRol() in ['profesor', 'admin']
                    && resource.data.profesorId == request.auth.uid; // Solo el creador puede editarlo

      match /intentos/{estudianteUid} {
        allow read: if request.auth.uid == estudianteUid || getRol() in ['profesor','admin'];
        allow update: if request.auth.uid == estudianteUid || getRol() in ['profesor','admin'];
      }
    }
  }
}
