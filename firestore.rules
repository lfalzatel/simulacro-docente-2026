rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPERS
    // ============================================
    function getRol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function estaAutenticado() {
      return request.auth != null;
    }

    function esAdmin() {
      return estaAutenticado() && getRol() == 'admin';
    }

    function esProfesor() {
      return estaAutenticado() && (getRol() == 'profesor' || getRol() == 'docente' || getRol() == 'DOCENTE' || getRol() == 'admin' || getRol() == 'ADMIN');
    }

    function esCreadorDelExamen(profesorId) {
      return estaAutenticado() && request.auth.uid == profesorId;
    }

    // ============================================
    // USUARIOS (roles: admin / profesor / estudiante / free)
    // ============================================
    match /usuarios/{userId} {
      allow read: if estaAutenticado();

      allow create: if request.auth.uid == userId; // el usuario se crea a sí mismo en el primer login

      allow update: if request.auth.uid == userId
                    || esAdmin()
                    || (esProfesor() && request.resource.data.rol == 'estudiante');
    }

    // ============================================
    // NOTIFICACIONES
    // ============================================
    match /notificaciones/{notifId} {
      allow read: if estaAutenticado();
      allow create: if esProfesor() || esAdmin();
      allow update: if estaAutenticado();
      allow delete: if esAdmin() || esProfesor();
    }

    // ============================================
    // NOTAS
    // ============================================
    match /notas/{notaId} {
      allow read, update, delete: if estaAutenticado() && request.auth.uid == resource.data.userId;
      allow create: if estaAutenticado() && request.resource.data.userId == request.auth.uid;
    }

    // ============================================
    // EXAMENES (Soporta esquema antiguo y nuevo)
    // ============================================
    match /examenes/{examenId} {
      allow read: if estaAutenticado();

      allow create: if (esProfesor() || esAdmin())
                    && (
                      // Esquema antiguo
                      (
                        request.resource.data.profesorId == request.auth.uid
                        && request.resource.data.titulo is string
                        && request.resource.data.titulo.size() > 0
                        && request.resource.data.titulo.size() <= 120
                        && request.resource.data.grupoId is string
                        && request.resource.data.bancoPreguntas in ['quizData', 'quizData2', 'quizData3']
                        && request.resource.data.estado == 'inactivo'
                      )
                      ||
                      // Esquema nuevo
                      (
                        request.resource.data.teacherId == request.auth.uid
                        && request.resource.data.title is string
                        && request.resource.data.group is string
                      )
                    );

      allow update: if esAdmin() 
                    || (('profesorId' in resource.data) && esCreadorDelExamen(resource.data.profesorId))
                    || (('teacherId' in resource.data) && esCreadorDelExamen(resource.data.teacherId));
                    
      allow delete: if esAdmin() 
                    || (('profesorId' in resource.data) && esCreadorDelExamen(resource.data.profesorId))
                    || (('teacherId' in resource.data) && esCreadorDelExamen(resource.data.teacherId));

      // ============================================
      // INTENTOS (subcolección: un doc por estudiante) - Esquema Antiguo
      // ============================================
      match /intentos/{estudianteUid} {
        allow read: if request.auth.uid == estudianteUid || esProfesor() || esAdmin();

        // El estudiante crea su propio intento al entrar por primera vez.
        allow create: if request.auth.uid == estudianteUid
                      && request.resource.data.estado == 'no_iniciado';

        // El estudiante puede actualizar su propio intento (autoguardado de
        // respuestas, o auto-bloquearse al detectar fraude) MIENTRAS no esté
        // ya bloqueado — desbloquear es exclusivo del profesor/admin.
        allow update: if (request.auth.uid == estudianteUid && resource.data.estado != 'bloqueado')
                      || esProfesor()
                      || esAdmin();
      }
    }

    // ============================================
    // RESPUESTAS EXAMENES
    // ============================================
    match /respuestas_examenes/{respuestaId} {
      // El profesor puede leer todas, el estudiante solo las suyas
      allow read: if esProfesor() || esAdmin() || (estaAutenticado() && resource.data.studentId == request.auth.uid);

      // El estudiante puede crear su respuesta al iniciar o al terminar
      allow create: if estaAutenticado() && request.resource.data.studentId == request.auth.uid;

      // El estudiante puede actualizar su respuesta (ej. marcar infracciones, auto-guardado, finalizar)
      // El profesor puede actualizar para calificar manualmente o desbloquear
      allow update: if (estaAutenticado() && resource.data.studentId == request.auth.uid) || esProfesor() || esAdmin();
      
      // Permitir al profesor eliminar la respuesta para que el estudiante repita
      allow delete: if esProfesor() || esAdmin();
    }
  }
}
